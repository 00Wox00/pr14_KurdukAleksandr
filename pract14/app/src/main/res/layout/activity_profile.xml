<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4CAF82">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:text="@string/profile_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"/>

    <!-- Кнопка назад -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="#FF8A65"
        android:src="@android:drawable/ic_media_previous"
        android:scaleType="centerInside"
        android:contentDescription="@string/back"/>

    <!-- Аватар -->
    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/tvTitle"
        android:layout_marginTop="40dp"
        android:src="@android:drawable/ic_menu_my_calendar"
        android:background="#FF9800"
        android:scaleType="centerInside"
        android:contentDescription="@string/avatar"/>

    <!-- Статус -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ivAvatar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="@string/not_logged_in"
        android:textSize="16sp"
        android:textColor="#FFFFFF"/>

    <!-- Кнопка Войти -->
    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_below="@id/tvStatus"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="@string/login"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#A5D6A7"/>

    <!-- Кнопка Регистрация -->
    <Button
        android:id="@+id/btn_register"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_below="@id/btn_login"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="@string/register"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#A5D6A7"/>

    <!-- Нижняя навигация -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#8BC34A"
        android:baselineAligned="false"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/listButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_list"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_format_list_bulleted_24"
            app:drawableTint="#FF5252"/>

        <TextView
            android:id="@+id/alarmButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_alarm"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_access_alarm_24"
            app:drawableTint="#FF5252"/>

        <TextView
            android:id="@+id/calendarButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_calendar"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_calendar_today_24"
            app:drawableTint="#FF5252"/>

        <TextView
            android:id="@+id/settingsButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_settings"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_settings_24"
            app:drawableTint="#FFFFFF"/>

    </LinearLayout>

</RelativeLayout>
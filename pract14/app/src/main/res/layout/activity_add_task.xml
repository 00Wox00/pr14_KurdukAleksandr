<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4CAF82"
    android:padding="16dp"
    android:stretchColumns="*">

    <!-- Строка 1: Заголовок + кнопка назад -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="284dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Добавить задачу"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:id="@+id/backButton"
            android:layout_width="6dp"
            android:layout_height="48dp"
            android:background="#FF8A65">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerInParent="true"
                android:contentDescription="Назад"
                android:src="@android:drawable/ic_media_previous"
                />
        </RelativeLayout>
    </TableRow>

    <!-- Строка 2: Поле заголовка задачи -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_span="2"
            android:hint="Заголовок задачи"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:inputType="text"/>
    </TableRow>

    <!-- Строка 3: Время + Дата -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/et_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="⏰  16:30"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:inputType="time"/>

        <EditText
            android:id="@+id/et_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:hint="📅  14.01.2021"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:inputType="date"/>
    </TableRow>

    <!-- Строка 4: Описание задачи -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/et_description"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_span="2"
            android:hint="Описание задачи"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:textSize="15sp"
            android:inputType="textMultiLine"
            android:gravity="top"/>
    </TableRow>

    <!-- Пустая строка-распорка -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Строка 5: Кнопка Записать задачу -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_span="2"
            android:text="Записать задачу"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#A5D6A7"/>
    </TableRow>

    <!-- Нижняя навигация -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_span="2"
            android:orientation="horizontal"
            android:background="#8BC34A"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/listButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_format_list_bulleted_24"
                    android:tint="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="List"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/alarmButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_access_alarm_24"
                    android:tint="#FF5252"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alarm"
                    android:textColor="#FF5252"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/calendarButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_calendar_today_24"
                    android:tint="#FF5252"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calendar"
                    android:textColor="#FF5252"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/settingsButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_settings_24"
                    android:tint="#FF5252"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="#FF5252"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>
    </TableRow>

</TableLayout>
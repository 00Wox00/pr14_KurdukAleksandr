<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4CAF82"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- GridLayout: заголовок + поля + чекбоксы -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="11">

            <!-- Заголовок -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="0"
                android:layout_columnWeight="1"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:text="@string/edit_alarm"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <!-- Кнопка назад -->
            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_column="1"
                android:layout_row="0"
                android:layout_gravity="end|center_vertical"
                android:layout_marginBottom="20dp"
                android:background="#FF8A65"
                android:src="@android:drawable/ic_media_previous"
                android:scaleType="centerInside"
                android:contentDescription="@string/back"/>

            <!-- Время -->
            <EditText
                android:id="@+id/et_alarm_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="1"
                android:layout_columnWeight="1"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="12dp"
                android:hint="@string/time_hint"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:textSize="15sp"
                android:inputType="time"
                android:autofillHints="no"/>

            <!-- Дата -->
            <EditText
                android:id="@+id/et_alarm_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="1"
                android:layout_row="1"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="12dp"
                android:hint="@string/date_hint"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:textSize="15sp"
                android:inputType="date"
                android:autofillHints="no"/>

            <!-- Метка -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="2"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="8dp"
                android:text="@string/repeat_daily"
                android:textSize="14sp"
                android:textColor="#FFFFFF"/>

            <!-- Понедельник -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="3"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"
                android:text="@string/monday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

            <!-- Вторник -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="4"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"
                android:text="@string/tuesday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

            <!-- Среда -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="5"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"
                android:text="@string/wednesday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

            <!-- Четверг -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="6"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"
                android:text="@string/thursday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

            <!-- Пятница -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="7"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"
                android:text="@string/friday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

            <!-- Суббота -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="8"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"
                android:text="@string/saturday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

            <!-- Воскресенье -->
            <CheckBox
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_column="0"
                android:layout_row="9"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_marginBottom="24dp"
                android:text="@string/sunday"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:buttonTint="#FFD54F"/>

        </GridLayout>

        <!-- Кнопка Удалить будильник -->
        <Button
            android:id="@+id/deleteButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="@string/delete_alarm"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EF5350"/>

        <!-- Кнопка Сохранить будильник -->
        <Button
            android:id="@+id/addButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:text="@string/save_alarm"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#A5D6A7"/>

        <!-- Нижняя навигация -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#8BC34A"
            android:baselineAligned="false"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/listButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_list"
                android:textColor="#FF5252"
                android:textSize="11sp"
                android:drawableTop="@drawable/baseline_format_list_bulleted_24"
                app:drawableTint="#FF5252"/>

            <TextView
                android:id="@+id/alarmButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_alarm"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:drawableTop="@drawable/baseline_access_alarm_24"
                app:drawableTint="#FFFFFF"/>

            <TextView
                android:id="@+id/calendarButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_calendar"
                android:textColor="#FF5252"
                android:textSize="11sp"
                android:drawableTop="@drawable/baseline_calendar_today_24"
                app:drawableTint="#FF5252"/>

            <TextView
                android:id="@+id/settingsButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/nav_settings"
                android:textColor="#FF5252"
                android:textSize="11sp"
                android:drawableTop="@drawable/baseline_settings_24"
                app:drawableTint="#FF5252"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
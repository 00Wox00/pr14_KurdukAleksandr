<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#4CAF82"
    android:padding="16dp">

    <!-- Заголовок + кнопка профиля -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/task_list"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#7B68EE"
            android:padding="8dp"/>

        <ImageButton
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="#FF6B6B"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:scaleType="centerInside"
            android:contentDescription="@string/profile_title"/>
    </LinearLayout>

    <!-- Карточка задачи 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:background="#A5D6A7"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task1_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task1_desc"
                android:textSize="13sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task1_date"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Карточка задачи 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:background="#A5D6A7"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task2_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task2_desc"
                android:textSize="13sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task2_date"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Карточка задачи 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:background="#A5D6A7"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task3_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/task3_desc"
                android:textSize="13sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task3_date"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Пустое пространство -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Кнопка Добавить задачу -->
    <Button
        android:id="@+id/addTaskButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/add_task_btn"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#A5D6A7"
        android:layout_marginBottom="8dp"/>

    <!-- Нижняя навигация -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#8BC34A"
        android:baselineAligned="false"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/listButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_list"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_format_list_bulleted_24"
            app:drawableTint="#FFFFFF"/>

        <TextView
            android:id="@+id/alarmButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_alarm"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_access_alarm_24"
            app:drawableTint="#FF5252"/>

        <TextView
            android:id="@+id/calendarButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_calendar"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_calendar_today_24"
            app:drawableTint="#FF5252"/>

        <TextView
            android:id="@+id/settingsButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_settings"
            android:textColor="#FF5252"
            android:textSize="11sp"
            android:drawableTop="@drawable/baseline_settings_24"
            app:drawableTint="#FF5252"/>

    </LinearLayout>

</LinearLayout>